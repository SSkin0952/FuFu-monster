<mujoco model="biped">
    <compiler angle="radian" balanceinertia="true"/>

    <asset>
        <mesh name="main_body_mesh" file="mesh\0.STL" scale="0.001 0.001 0.001"/>
        <mesh name="right_hip_mesh"   file="mesh\1.STL"   scale="0.001 0.001 0.001"/>
        <mesh name="left_hip_mesh"   file="mesh\2.STL"   scale="0.001 0.001 0.001"/>
        <mesh name="right_knee_mesh"   file="mesh\3.STL"   scale="0.001 0.001 0.001"/>
        <mesh name="left_knee_mesh"   file="mesh\4.STL"   scale="0.001 0.001 0.001"/>
        <mesh name="right_ankle_mesh"   file="mesh\5.STL"   scale="0.001 0.001 0.001"/>
        <mesh name="left_ankle_mesh"   file="mesh\6.STL"   scale="0.001 0.001 0.001"/>
        <mesh name="right_hair_mesh"   file="mesh\7.STL"   scale="0.001 0.001 0.001"/>
        <mesh name="left_hair_mesh"   file="mesh\8.STL"   scale="0.001 0.001 0.001"/>

        <texture type="skybox" builtin="gradient" rgb1="1 1 1" rgb2=".1 .15 0.2"
                 width="512" height="256"/>

        <texture name="texplane" type="2d" builtin="checker"
                 rgb1=".2 .3 .4" rgb2="0.1 0.05 0.2"
                 width="512" height="512"/>

        <material name="matplane" texture="texplane"/>
    </asset>
    <sensor>
        <!-- 加速度：包含重力 -->
        <accelerometer name="imu_accel" site="imu_site"/>

        <!-- 角速度 -->
        <gyro name="imu_gyro" site="imu_site"/>

        <!-- 姿态四元数 -->
        <framequat name="imu_quat" objtype="site" objname="imu_site"/>
    </sensor>
    <option timestep="0.002" integrator="implicit"
            iterations="50" tolerance="1e-8"
            gravity="0 0 -9.81"
            impratio="1"
            cone="elliptic"
            o_margin="0.02"
            o_solref="0.002 1"
            o_solimp="0.99 0.99 0.01"
    />

    <worldbody>
        <light directional="true" diffuse=".4 .4 .4" specular="0.1 0.1 0.1"
               pos="0 0 3" dir="0 0 -1"/>

        <geom name="floor" type="plane"
              size="1 1 0.01"
              friction="3 0.2 0.1"
              solref="0.002 1"
              solimp="0.99 0.99 0.01"
              material="matplane"
        />

        <body name="main_body" pos="0 0 0.235">
            <freejoint name="root_joint"/>
            <inertial pos="0.00247 -0.00362 0.003144" mass="1.2"
                  fullinertia="4.6e-3 8.7e-3 9e-3  -6.6e-6 -9.6e-7 4.8e-6"/>
            <geom type="mesh" mesh="main_body_mesh" rgba="0.4 0.1 0.3 1" euler="0 0 0"/>
            <site name="imu_site" pos="0 0 0.1" size="0.01"/>
            <body name="right_hip" pos="0 -0.00355 -0.0454">
                <inertial pos="-0.0451 -0.00355 -0.08015" mass="0.030"
                          fullinertia="6.7e-6 9e-6 1.1e-5  0 0 0"/>
                <joint name="right_hip_joint" type="hinge" axis="1 0 0"
                       range="-1.57 1.57" damping="3"/>
                <geom type="mesh" mesh="right_hip_mesh"
                      pos="0 0.00355 0.0454"
                      rgba="0.2 0.4 0.3 1"
                      friction="0.6 0.05 0.01"
                      euler="0 0 0"/>
                <body name="right_knee" pos="0 0 -0.0675">
                    <inertial pos="-0.04475 -0.00355 -0.15585" mass="0.130"
                              fullinertia="1.8e-5 1.2e-4 1.3e-4  0 0 0"/>
                    <joint name="right_knee_joint" type="hinge" axis="1 0 0"
                           range="-1.57 1.57" damping="3"/>
                    <geom type="mesh" mesh="right_knee_mesh"
                          pos="0 0.00355 0.1149"
                          rgba="0.5 0.5 0.5 1"
                          friction="0.6 0.05 0.01"
                          euler="0 0 0"/>
                    <body name="right_ankle" pos="0 0 -0.0819">
                        <inertial pos="-0.05172 -0.00415 -0.23197" mass="0.060"
                                  fullinertia="3.2e-5 6.8e-5 9.5e-5  -1.7e-6 1.1e-6 9.4e-8"/>
                        <joint name="right_ankle_joint" type="hinge" axis="1 0 0"
                               range="-1.57 1.57" damping="3"/>
                        <geom type="mesh" mesh="right_ankle_mesh"
                              pos="0 0.00355 0.1968"
                              rgba="0.2 0.3 0.4 1"
                              contype="0" conaffinity="0"
                              group="2"
                              euler="0 0 0"/>
                        <geom type="box" size="0.033 0.06 0.003" pos="-0.0571 0 -0.0377"
                              rgba="1 1 1 1"
                              friction="30 0.2 0.1"
                              solref="0.005 1"
                              solimp="0.99 0.99 0.001"
                              priority="1"/>
                        <geom type="box" size="0.017 0.005 0.003" pos="-0.0071 0.035 -0.0377"
                              rgba="1 1 1 1"
                              friction="30 0.2 0.1"
                              solref="0.005 1"
                              solimp="0.99 0.99 0.001"
                              priority="1"/>
                        <geom type="box" size="0.017 0.005 0.003" pos="-0.0071 -0.055 -0.0377"
                              rgba="1 1 1 1"
                              friction="30 0.2 0.1"
                              solref="0.005 1"
                              solimp="0.99 0.99 0.001"
                              priority="1"/>
                    </body>
                </body>
            </body>
            <body name="left_hip" pos="0 -0.00355 -0.0454">
                <inertial pos="0.0461 -0.00355 -0.08015" mass="0.030"
                          fullinertia="6.7e-6 9e-6 1.1e-5  0 0 0"/>
                <joint name="left_hip_joint" type="hinge" axis="1 0 0"
                       range="-1.57 1.57" damping="3"/>
                <geom type="mesh" mesh="left_hip_mesh"
                      pos="0 0.00355 0.0454"
                      rgba="0.2 0.4 0.3 1"
                      friction="0.6 0.05 0.01"
                      euler="0 0 0"/>
                <body name="left_knee" pos="0 0 -0.0675">
                    <inertial pos="0.04576 -0.00355 -0.15585" mass="0.130"
                              fullinertia="1.8e-5 1.2e-4 1.3e-4  0 0 0"/>
                    <joint name="left_knee_joint" type="hinge" axis="1 0 0"
                           range="-1.57 1.57" damping="3"/>
                    <geom type="mesh" mesh="left_knee_mesh"
                          pos="0 0.00355 0.1149"
                          rgba="0.5 0.5 0.5 1"
                          friction="0.6 0.05 0.01"
                          euler="0 0 0"/>
                    <body name="left_ankle" pos="0 0 -0.0819">
                        <inertial pos="0.05277 -0.00295 -0.23197" mass="0.060"
                                  fullinertia="3.2e-5 6.8e-5 9.5e-5  -1.7e-6 1.1e-6 -9.4e-8"/>
                        <joint name="left_ankle_joint" type="hinge" axis="1 0 0"
                               range="-1.57 1.57" damping="3"/>
                        <geom type="mesh" mesh="left_ankle_mesh"
                              pos="0 0.00355 0.1968"
                              rgba="0.2 0.3 0.4 1"
                              contype="0" conaffinity="0"
                              group="2"
                              euler="0 0 0"/>
                        <geom type="box" size="0.033 0.06 0.003" pos="0.05815 0 -0.0377"
                              rgba="1 1 1 1"
                              friction="30 0.2 0.1"
                              solref="0.005 1"
                              solimp="0.99 0.99 0.001"
                              priority="1"/>
                        <geom type="box" size="0.017 0.005 0.003" pos="0.00815 -0.035 -0.0377"
                              rgba="1 1 1 1"
                              friction="30 0.2 0.1"
                              solref="0.005 1"
                              solimp="0.99 0.99 0.001"
                              priority="1"/>
                        <geom type="box" size="0.017 0.005 0.003" pos="0.00815 0.055 -0.0377"
                              rgba="1 1 1 1"
                              friction="30 0.2 0.1"
                              solref="0.005 1"
                              solimp="0.99 0.99 0.001"
                              priority="1"/>
                    </body>
                </body>
            </body>
            <body name="right_hair" pos="-0.157 0 0.01207">
                <inertial pos="-0.19574 -0.00328 -0.12648" mass="0.060"
                          fullinertia="4.8e-5 3.6e-4 3.8e-4  0 9.3e-5 0"/>
                <joint name="right_hair_joint" type="hinge" axis="0 1 0"
                       range="0 0.57" damping="3"/>
                <geom type="mesh" mesh="right_hair_mesh"
                      pos="0.157 0 -0.01207"
                      rgba="0.1 0.1 0.7 1"
                      friction="0.6 0.05 0.01"
                      euler="0 0 0"/>
            </body>
            <body name="left_hair" pos="0.15924 0 0.01215">
                <inertial pos="0.19575 -0.00282 -0.12648" mass="0.060"
                          fullinertia="4.8e-5 3.6e-4 3.8e-4  0 -9.3e-5 2.8e-8"/>
                <joint name="left_hair_joint" type="hinge" axis="0 1 0"
                       range="-0.57 0" damping="3"/>
                <geom type="mesh" mesh="left_hair_mesh"
                      pos="-0.15924 0 -0.01215"
                      rgba="0.1 0.1 0.7 1"
                      friction="0.6 0.05 0.01"
                      euler="0 0 0"/>
            </body>
        </body>
    </worldbody>
    <actuator>
        <position name="right_hip_servo" joint="right_hip_joint" kp="300" kv="30" ctrlrange="-1.57 1.57" forcerange="-10 10"/>
        <position name="left_hip_servo" joint="left_hip_joint" kp="300" kv="30" ctrlrange="-1.57 1.57" forcerange="-10 10"/>
        <position name="right_knee_servo" joint="right_knee_joint" kp="300" kv="30" ctrlrange="-1.57 1.57" forcerange="-10 10"/>
        <position name="left_knee_servo" joint="left_knee_joint" kp="300" kv="30" ctrlrange="-1.57 1.57" forcerange="-10 10"/>
        <position name="right_ankle_servo" joint="right_ankle_joint" kp="300" kv="30" ctrlrange="-1.57 1.57" forcerange="-10 10"/>
        <position name="left_ankle_servo" joint="left_ankle_joint" kp="300" kv="30" ctrlrange="-1.57 1.57" forcerange="-10 10"/>
        <position name="right_hair_servo" joint="right_hair_joint" kp="300" kv="30" ctrlrange="0 1.57" forcerange="-10 10"/>
        <position name="left_hair_servo" joint="left_hair_joint" kp="300" kv="30" ctrlrange="-1.57 0" forcerange="-10 10"/>
    </actuator>
</mujoco>